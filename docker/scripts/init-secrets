#!/bin/sh

set -euo pipefail

KEYS_DIR="/app/var/data/keys"

setup_jwt_keys() {
  local config_jwt_dir="/services/api/config/jwt"

  mkdir -p "$KEYS_DIR"
  mkdir -p "$config_jwt_dir"
  chmod 750 "$config_jwt_dir"

  if [ ! -f "$KEYS_DIR/private.pem" ] || [ ! -f "$KEYS_DIR/public.pem" ]; then
    echo "[system:init] Generating new JWT keypair..."

    local passphrase=$(openssl rand -hex 32)
    echo "$passphrase" > "$KEYS_DIR/passphrase"
    chmod 640 "$KEYS_DIR/passphrase"

    openssl genpkey -algorithm RSA -out "$KEYS_DIR/private.pem" -pkeyopt rsa_keygen_bits:4096 -aes256 -pass pass:"$passphrase" 2>/dev/null
    openssl rsa -pubout -in "$KEYS_DIR/private.pem" -out "$KEYS_DIR/public.pem" -passin pass:"$passphrase" 2>/dev/null

    chmod 640 "$KEYS_DIR/private.pem"
    chmod 644 "$KEYS_DIR/public.pem"

    echo "[system:init] JWT keypair generated"
  fi

  if [ -f "$KEYS_DIR/private.pem" ]; then
    if [ ! -f "$KEYS_DIR/passphrase" ] || ! openssl rsa -in "$KEYS_DIR/private.pem" -passin file:"$KEYS_DIR/passphrase" -check -noout >/dev/null 2>&1; then
      echo "[system:init] JWT keypair/passphrase mismatch, regenerating..."
      rm -f "$KEYS_DIR/private.pem" "$KEYS_DIR/public.pem" "$KEYS_DIR/passphrase"
      rm -f "$KEYS_DIR/mercure_secret" "$KEYS_DIR/app_secret"
      setup_jwt_keys
      return
    fi
  fi

  ln -sf "$KEYS_DIR/private.pem" "$config_jwt_dir/private.pem"
  ln -sf "$KEYS_DIR/public.pem" "$config_jwt_dir/public.pem"
}

setup_mercure_keys() {
  if [ ! -f "$KEYS_DIR/mercure_secret" ]; then
    openssl rand -hex 32 > "$KEYS_DIR/mercure_secret"
    chmod 640 "$KEYS_DIR/mercure_secret"
    echo "[system:init] Generated Mercure JWT secret"
  fi
}

setup_app_secret() {
  if [ ! -f "$KEYS_DIR/app_secret" ]; then
    local secret=$(openssl dgst -sha256 -hex "$KEYS_DIR/private.pem" | awk '{print $2}')
    echo "$secret" > "$KEYS_DIR/app_secret"
    chmod 640 "$KEYS_DIR/app_secret"
    echo "[system:init] Generated APP_SECRET from JWT key"
  fi
}

setup_jwt_keys
setup_mercure_keys
setup_app_secret
