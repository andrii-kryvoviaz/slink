{
  "name": "slink-client",
  "version": "1.12.1",
  "private": true,
  "scripts": {
    "dev": "vite dev",
    "dev:with-deps": "yarn install --immutable && yarn dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint . && prettier --check .",
    "lint:fix": "eslint . --fix && prettier --write .",
    "format": "prettier --write .",
    "prepare": "cd ../.. && husky ./services/client/.husky",
    "i18n": "wuchale --clean",
    "i18n:extract": "wuchale extract",
    "i18n:compile": "wuchale compile",
    "e2e": "playwright test",
    "e2e:install": "playwright install --with-deps chromium"
  },
  "dependencies": {
    "clsx": "^2.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@floating-ui/dom": "^1.7.6",
    "@iconify/svelte": "5.2.2",
    "@internationalized/date": "^3.12.2",
    "@lucide/svelte": "^0.577.0",
    "@playwright/test": "^1.61.0",
    "@sveltejs/adapter-auto": "7.0.1",
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.66.0",
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "@tailwindcss/vite": "^4.3.1",
    "@tanstack/table-core": "^8.21.3",
    "@trivago/prettier-plugin-sort-imports": "6.0.2",
    "@types/dotenv": "^8.2.3",
    "@types/node": "24.10.2",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@vite-pwa/sveltekit": "^1.1.0",
    "@wuchale/svelte": "^0.20.0",
    "apexcharts": "5.15.2",
    "bits-ui": "^2.18.1",
    "class-variance-authority": "^0.7.1",
    "crawler-user-agents": "^1.52.0",
    "dotenv": "17.4.2",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.19.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "17.0.7",
    "mode-watcher": "^1.1.0",
    "prettier": "^3.8.4",
    "prettier-plugin-svelte": "4.1.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "redis": "6.0.0",
    "svelte": "^5.56.3",
    "svelte-check": "^4.6.0",
    "svelte-eslint-parser": "^1.8.0",
    "svelte-sonner": "^1.1.1",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.1",
    "tslib": "^2.8.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "8.0.16",
    "vite-plugin-pwa": "^1.3.0",
    "workbox-window": "^7.4.1",
    "wuchale": "^0.24.2"
  },
  "lint-staged": {
    "*.{js,ts,svelte}": [
      "eslint --fix",
      "svelte-kit sync",
      "svelte-check --tsconfig ./tsconfig.json",
      "prettier --write"
    ],
    "*.{json,md,css,html}": [
      "prettier --write"
    ]
  },
  "type": "module",
  "resolutions": {
    "lodash": ">=4.18.1",
    "lodash-es": ">=4.18.1",
    "flatted": ">=3.4.2",
    "picomatch": ">=4.0.4",
    "minimatch": ">=10.0.0",
    "serialize-javascript": ">=7.0.0",
    "cookie": "^0.7.2",
    "postcss": "^8.5.10",
    "workbox-build/rollup": "^2.80.0",
    "@sveltejs/adapter-node/rollup": "4.59.1",
    "@babel/plugin-transform-modules-systemjs": "^7.29.4",
    "@babel/core": "^7.29.6",
    "fast-uri": "^3.1.2"
  }
}
